---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../lib/seo';
import { organizationSchema } from '../lib/schema/organization';
import { websiteSchema } from '../lib/schema/website';
import { softwareApplicationSchema } from '../lib/schema/softwareApplication';
import { breadcrumbSchema } from '../lib/schema/breadcrumb';

const schema = [
  organizationSchema(),
  websiteSchema(),
  softwareApplicationSchema({ url: SITE.domain + '/' }),
  breadcrumbSchema([{ name: 'Home', item: SITE.domain + '/' }]),
];
---
<BaseLayout
  seo={{
    title: 'Geo Tags Editor to Add or Remove GPS from Photos Free',
    description:
      'Add or remove GPS coordinates from JPEG photos directly in your browser. No upload, no account needed. Free private EXIF GPS editor for desktop and mobile.',
    canonicalPath: '/',
    ogImage: '/images/og-home.png',
  }}
  schema={schema}
>
  <section class="hero" aria-label="Homepage hero">
    <div class="container">
      <span class="section-label">Free GPS &amp; EXIF Photo Editor</span>
      <h1>
        Free GPS <span class="gradient-text">Photo Editor Online</span>
      </h1>
      <p>
        Edit GPS coordinates inside JPEG photos directly in your browser. No account. No upload. No software to
        install. Works on desktop, iPhone and Android in seconds.
      </p>
      <div class="hero-buttons">
        <a class="btn btn-primary" href="#tool">Open Free GPS Editor</a>
        <a class="btn btn-outline" href="/remove-geotag-from-photo-online/">Remove GPS from Photo</a>
      </div>
      <p class="mt-3" style="color: var(--text-secondary); font-size: 0.95rem;">
        Photos never leave your device • Unlimited • $0 forever
      </p>
    </div>
  </section>

  <section class="section tool-section" id="tool" aria-label="GPS photo editor tool">
    <div class="container" style="max-width: 860px;">
      <div class="section-header" style="margin-bottom: 28px;">
        <h2>Try the GPS Photo Editor Online</h2>
        <p>Upload a photo and test the tool. Add, edit, or remove GPS coordinates instantly — no signup.</p>
      </div>

      <!-- Tool embed (preserved markup for existing JS tool) -->
      <div class="tool-card" id="tool-card">
        <div class="tool-steps" role="tablist" aria-label="Geo tag editor steps">
          <button class="tool-step-tab active" id="tabUpload" role="tab" aria-controls="uploadSection" aria-selected="true" tabindex="0">
            <svg class="icon"><use href="/images/icons.svg#icon-upload"></use></svg> Upload
          </button>
          <button class="tool-step-tab" id="tabEdit" role="tab" aria-controls="editSection" aria-selected="false" tabindex="-1">
            <svg class="icon"><use href="/images/icons.svg#icon-edit"></use></svg> Edit GPS
          </button>
          <button class="tool-step-tab" id="tabDownload" role="tab" aria-controls="downloadSection" aria-selected="false" tabindex="-1">
            <svg class="icon"><use href="/images/icons.svg#icon-download"></use></svg> Download
          </button>
        </div>

        <div class="tool-body">
          <div id="uploadSection" role="tabpanel" aria-labelledby="tabUpload">
            <div class="drop-zone" id="dropZone" role="button" aria-label="Upload JPEG images">
              <label for="fileInput" class="sr-only">Upload JPEG images</label>
              <input type="file" id="fileInput" accept=".jpg,.jpeg,image/jpeg" multiple aria-label="Choose JPEG images to upload" />
              <span class="dz-icon" aria-hidden="true"><svg class="icon"><use href="/images/icons.svg#icon-image"></use></svg></span>
              <p>Drag &amp; drop your JPEG images here (up to 20)<br />or <span class="browse">click to browse</span></p>
            </div>
            <div id="uploadedImagesPreview" style="margin-top:20px;display:none"></div>
            <button class="btn btn-outline btn-sm" id="addMoreBtn" style="margin-top:16px;display:none">
              <svg class="icon"><use href="/images/icons.svg#icon-upload"></use></svg> Add More Images
            </button>
          </div>

          <div id="editSection" class="hidden" role="tabpanel" aria-labelledby="tabEdit" hidden>
            <div class="preview-area visible" id="previewArea">
              <div id="imagesPreviewContainer"></div>
              <button class="btn btn-danger btn-sm" id="removeBtn" style="margin-top:12px">
                <svg class="icon icon-sm"><use href="/images/icons.svg#icon-close"></use></svg> Remove All Images
              </button>
            </div>

            <details open style="margin-top:16px">
              <summary style="font-weight:600;cursor:pointer;margin-bottom:12px;font-size:.95rem;display:flex;align-items:center;gap:8px">
                <svg class="icon" style="width:1em;height:1em"><use href="/images/icons.svg#icon-metadata"></use></svg>
                EXIF Metadata
              </summary>
              <table class="meta-table"><tbody id="metaBody"></tbody></table>
            </details>

            <div class="coord-form">
              <h3 style="font-size:1rem;font-weight:600;margin-bottom:16px;display:flex;align-items:center;gap:8px">
                <svg class="icon" style="width:1.1em;height:1.1em" aria-hidden="true"><use href="/images/icons.svg#icon-location"></use></svg>
                Set GPS Coordinates
              </h3>
              <div class="coord-grid">
                <div class="field">
                  <label for="latInput">Latitude</label>
                  <input type="number" id="latInput" step="any" min="-90" max="90" placeholder="e.g. 48.8566" />
                  <p class="hint">Range: -90 to 90 (negative = South)</p>
                </div>
                <div class="field">
                  <label for="lngInput">Longitude</label>
                  <input type="number" id="lngInput" step="any" min="-180" max="180" placeholder="e.g. 2.3522" />
                  <p class="hint">Range: -180 to 180 (negative = West)</p>
                </div>
              </div>

              <button type="button" class="btn-location" id="getCurrentLocBtn">
                <span class="spinner"></span> <span class="icon-loc"></span> <span id="locBtnText">📍 Get My Current Location</span>
              </button>

              <h3 style="font-size:1rem;font-weight:600;margin:24px 0 8px;display:flex;align-items:center;gap:8px">
                <svg class="icon" style="width:1.1em;height:1.1em" aria-hidden="true"><use href="/images/icons.svg#icon-map"></use></svg>
                Pick Location on Map
              </h3>
              <p style="font-size:.85rem;color:var(--text-muted);margin-bottom:8px">Click anywhere on the map or drag the marker to set coordinates.</p>
              <div class="map-container" id="mapContainer"></div>
            </div>

            <div class="tool-actions">
              <button class="btn btn-primary" id="applyBtn" disabled>
                <svg class="icon"><use href="/images/icons.svg#icon-location"></use></svg> Apply Coordinates
              </button>
              <button class="btn btn-danger" id="removeGpsBtn">
                <svg class="icon"><use href="/images/icons.svg#icon-shield"></use></svg> Remove Geotag
              </button>
            </div>
            <div class="result-banner" id="resultBanner"><span id="resultText"></span></div>
            <div id="processedImagesContainer" style="margin-top:24px;display:none"></div>
          </div>

          <div id="downloadSection" class="hidden" role="tabpanel" aria-labelledby="tabDownload" hidden>
            <div style="text-align:center;padding:20px 0">
              <div style="margin-bottom:12px">
                <svg class="icon" style="width:48px;height:48px;color:var(--success);display:block;margin:0 auto"><use href="/images/icons.svg#icon-check"></use></svg>
              </div>
              <h3 style="margin-bottom:8px">Image Ready for Download</h3>
              <p style="color:var(--text-secondary);margin-bottom:20px;font-size:.95rem">
                Your image has been updated with the new GPS metadata. Preview it below and download when ready.
              </p>
              <div class="preview-img-wrap" style="margin-bottom:20px;max-height:300px">
                <img id="dlPreviewImg" alt="Updated image preview" loading="lazy" decoding="async" width="600" height="300" style="max-height:300px;width:auto;height:auto" />
              </div>
              <button class="btn btn-success" id="downloadBtn" style="min-width:220px">
                <svg class="icon"><use href="/images/icons.svg#icon-download"></use></svg> Download Geotagged Image
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="features" aria-labelledby="features-heading">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Tool features</span>
        <h2 id="features-heading">Everything you need to manage photo GPS</h2>
        <p>A complete browser-based EXIF GPS editor. No installs, no subscriptions, no data leaving your device.</p>
      </div>

      <div class="grid-3">
        <div class="card">
          <h3>Geo tagging</h3>
          <p>Add GPS coordinates to JPEG photos using a map or exact latitude/longitude values.</p>
        </div>
        <div class="card">
          <h3>EXIF metadata support</h3>
          <p>View embedded metadata before edits, then write updated GPS cleanly without re-encoding pixels.</p>
        </div>
        <div class="card">
          <h3>Coordinate editing</h3>
          <p>Fix incorrect locations by dragging the pin or typing precise coordinates.</p>
        </div>
        <div class="card">
          <h3>Bulk editing</h3>
          <p>Apply the same coordinate set to multiple photos for faster campaign workflows.</p>
        </div>
        <div class="card">
          <h3>Privacy-first removal</h3>
          <p>Strip GPS data before sharing photos with clients, marketplaces, or social media.</p>
        </div>
        <div class="card">
          <h3>Local SEO optimization</h3>
          <p>Prepare image metadata for Google Business Profile and local search discovery workflows.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="how-it-works" aria-labelledby="how-heading" style="background: var(--gradient-soft);">
    <div class="container">
      <div class="section-header">
        <span class="section-label">How it works</span>
        <h2 id="how-heading">Edit photo GPS metadata in 4 steps</h2>
        <p>Upload → add or remove GPS → save metadata → download. No account required.</p>
      </div>
      <div class="steps">
        <div class="step">
          <div class="step-num">1</div>
          <h3>Upload image</h3>
          <p>Drag &amp; drop a JPEG from desktop or choose from your camera roll.</p>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <h3>Add GPS coordinates</h3>
          <p>Pick a location on the map or enter exact latitude/longitude.</p>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <h3>Save metadata</h3>
          <p>Apply changes without changing the image pixels or quality.</p>
        </div>
        <div class="step">
          <div class="step-num">4</div>
          <h3>Download optimized image</h3>
          <p>Save the updated JPEG locally. Your original file stays untouched.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="benefits" aria-labelledby="benefits-heading">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Benefits</span>
        <h2 id="benefits-heading">Built for local SEO teams and photo-heavy businesses</h2>
        <p>Fast workflows for agencies, businesses, photographers, realtors, and GBP optimizers.</p>
      </div>
      <div class="grid-4">
        <div class="card">
          <h3>Local SEO agencies</h3>
          <p>Standardize photo metadata across client locations and campaigns.</p>
        </div>
        <div class="card">
          <h3>Local businesses</h3>
          <p>Geotag storefront and job-site photos before uploading to GBP.</p>
        </div>
        <div class="card">
          <h3>Photographers</h3>
          <p>Batch-tag shoot locations or remove GPS for client privacy.</p>
        </div>
        <div class="card">
          <h3>Realtors</h3>
          <p>Attach accurate property coordinates to listing photo sets.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="internal-links" aria-labelledby="internal-links-heading" style="background: var(--bg);">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Resources</span>
        <h2 id="internal-links-heading">Guides for geotagging, EXIF, and GPS workflows</h2>
        <p>Learn the tactics behind accurate coordinates, privacy, and local SEO image strategy.</p>
      </div>
      <div class="grid-3">
        <a class="card-link" href="/blog/"><div class="card"><h3>Blog</h3><p>All tutorials and guides.</p></div></a>
        <a class="card-link" href="/blog/exif-data-ultimate-guide/"><div class="card"><h3>EXIF tutorials</h3><p>Understand what metadata stores and how to edit it safely.</p></div></a>
        <a class="card-link" href="/blog/why-geotagging-matters-for-local-seo/"><div class="card"><h3>Geo tagging for local SEO</h3><p>How geotagging can support GBP and local discovery.</p></div></a>
        <a class="card-link" href="/blog/how-geo-tagging-improves-local-seo-rankings/"><div class="card"><h3>Geo tagging improves rankings</h3><p>A practical 2026 workflow for GBP and local visibility.</p></div></a>
      </div>
    </div>
  </section>

  <section class="section" id="faq" aria-labelledby="faq-heading">
    <div class="container">
      <div class="section-header">
        <span class="section-label">FAQ</span>
        <h2 id="faq-heading">Frequently asked questions</h2>
      </div>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-question">Is Geo Tags Editor really free?</button>
          <div class="faq-answer"><div class="faq-answer-inner">Yes — the tool is free with no account, no signup, and no hidden limits.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">Are my photos uploaded to your servers?</button>
          <div class="faq-answer"><div class="faq-answer-inner">No. Your photos never leave your device. All processing happens in your browser.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">Does it work on iPhone and Android?</button>
          <div class="faq-answer"><div class="faq-answer-inner">Yes. It works in modern mobile browsers including Safari and Chrome.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">What image formats are supported?</button>
          <div class="faq-answer"><div class="faq-answer-inner">JPEG and JPG files. Convert HEIC/PNG/WebP to JPEG first.</div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="testimonials" aria-labelledby="testimonials-heading" style="background: var(--gradient-soft);">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Testimonials</span>
        <h2 id="testimonials-heading">Trusted workflows for teams that can’t risk uploads</h2>
        <p>Fast, private, and predictable results across devices.</p>
      </div>
      <div class="grid-3">
        <div class="card">
          <h3>Local SEO agency</h3>
          <p>“We can update GPS metadata in batches without sending client photos to a server.”</p>
        </div>
        <div class="card">
          <h3>Photographer</h3>
          <p>“The remove-GPS workflow is perfect for privacy before delivery.”</p>
        </div>
        <div class="card">
          <h3>Business owner</h3>
          <p>“Easy to tag storefront photos for GBP without installing any software.”</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" aria-label="Call to action">
    <div class="container" style="max-width: 900px;">
      <div class="cta-banner">
        <h2>Add or remove GPS from your photos now</h2>
        <p>Free. Private. No account. No upload. Works on any device in seconds.</p>
        <a class="btn" href="#tool" data-scroll-target="#tool">Open the GPS Editor</a>
      </div>
    </div>
  </section>

  <script src="/js/tool.js" defer></script>
</BaseLayout>

