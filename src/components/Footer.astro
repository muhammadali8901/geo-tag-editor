---
const quickLinks = [
  { href: '/', label: 'Home' },
  { href: '/add-gps-to-photo-online/', label: 'Add GPS' },
  { href: '/remove-geotag-from-photo-online/', label: 'Remove GPS' },
  { href: '/geo-tag-editor/', label: 'Geo Tag Editor' },
  { href: '/blog/', label: 'Blog' },
  { href: '/about/', label: 'About Us' },
  { href: '/contact/', label: 'Contact' },
];

const guideLinks = [
  { href: '/blog/how-to-add-geotag-to-existing-photos/', label: 'Add Geotag to Existing Photos' },
  { href: '/blog/how-to-remove-gps-exif-data-from-photos/', label: 'Remove GPS Geotags from Photo' },
  { href: '/blog/why-geotagging-matters-for-local-seo/', label: 'Geotagging for Local SEO' },
  { href: '/blog/exif-data-ultimate-guide/', label: 'EXIF Data Ultimate Guide' },
  { href: '/blog/how-to-add-gps-location-to-photos/', label: 'Add GPS to Photos' },
  { href: '/blog/how-to-geotag-photos-for-google-business-profile/', label: 'Geotag Photos for GBP' },
];

const legalLinks = [
  { href: '/privacy-policy/', label: 'Privacy Policy' },
  { href: '/terms/', label: 'Terms & Conditions' },
  { href: '/disclaimer/', label: 'Disclaimer' },
  { href: '/sitemap/', label: 'Sitemap' },
];

const year = new Date().getFullYear();
---

<footer class="site-footer" id="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="logo">
          <img src="/images/logo.webp" alt="Geo Tags Editor" width="32" height="32" style="height:32px;width:auto" loading="lazy" decoding="async" />
          <span>Geo Tags Editor</span>
        </div>
        <p>
          Geo Tags Editor is a free online tool that lets you add, edit, or remove GPS geotag metadata from your JPEG
          images. Fast, private, and entirely browser-based.
        </p>
      </div>

      <div class="footer-col">
        <p class="footer-title">Quick Links</p>
        <ul>
          {quickLinks.map((l) => (
            <li><a href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <p class="footer-title">Articles &amp; Guides</p>
        <ul>
          {guideLinks.map((l) => (
            <li><a href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <p class="footer-title">Legal</p>
        <ul>
          {legalLinks.map((l) => (
            <li><a href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      &copy; {year} Geo Tags Editor. All rights reserved. Free online geo tag editor tool.
    </div>
  </div>
</footer>

