---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { seo, type SeoConfig } from '../lib/seo';

type Props = {
  seo: Pick<SeoConfig, 'title' | 'canonicalPath'> & Partial<SeoConfig>;
  schema?: unknown[];
};

const {
  seo: seoInput,
  schema = [],
} = Astro.props;

const meta = seo(seoInput);
const canonicalUrl = new URL(meta.canonicalPath ?? Astro.url.pathname, Astro.site);
const ogImage = new URL(meta.ogImage ?? '/images/og-default.jpg', Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <meta name="robots" content={meta.robots} />
    <link rel="canonical" href={canonicalUrl.toString()} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Geo Tags Editor" />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:image" content={ogImage.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={meta.title} />
    <meta name="twitter:description" content={meta.description} />
    <meta name="twitter:image" content={ogImage.toString()} />

    <link rel="icon" type="image/png" sizes="32x32" href="/images/logo.webp" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/logo.webp" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="preload" href="/css/style.css" as="style" />
    <link rel="stylesheet" href="/css/style.css" />

    {schema.map((json) => (
      <script type="application/ld+json" set:html={JSON.stringify(json)}></script>
    ))}
  </head>
  <body>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <script src="/js/common.js" defer></script>
    <script src="/js/site.js" defer></script>
  </body>
</html>

