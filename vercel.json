{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "add-gps-to-photo-online.html",
      "use": "@vercel/static"
    },
    {
      "src": "remove-geotag-from-photo-online.html", 
      "use": "@vercel/static"
    },
    {
      "src": "geo-tag-editor/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "blog/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/add-gps-to-photo-online/",
      "dest": "/add-gps-to-photo-online.html"
    },
    {
      "src": "/remove-geotag-from-photo-online/", 
      "dest": "/remove-geotag-from-photo-online.html"
    },
    {
      "src": "/geo-tag-editor/",
      "dest": "/geo-tag-editor/index.html"
    },
    {
      "src": "/blog/",
      "dest": "/blog/index.html"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": true
}
