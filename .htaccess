# Geo Tags Editor — Performance & Security Optimization
# Apache/cPanel compatible

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Redirect index.html to /
RewriteRule ^index\.html$ / [R=301,L]

# Root-level .html to folder/
RewriteRule ^about\.html$ /about/ [R=301,L]
RewriteRule ^contact\.html$ /contact/ [R=301,L]
RewriteRule ^geo-tag-editor\.html$ /geo-tag-editor/ [R=301,L]
RewriteRule ^blog\.html$ /blog/ [R=301,L]
RewriteRule ^privacy-policy\.html$ /privacy-policy/ [R=301,L]
RewriteRule ^terms\.html$ /terms/ [R=301,L]
RewriteRule ^disclaimer\.html$ /disclaimer/ [R=301,L]
RewriteRule ^sitemap-page\.html$ /sitemap/ [R=301,L]

# Blog article .html to /blog/slug/
RewriteRule ^blog/([a-z0-9-]+)\.html$ /blog/$1/ [R=301,L]
</IfModule>

# Enable GZIP Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Browser Caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Cache Control Headers
<IfModule mod_headers.c>
  Header set Cache-Control "public, max-age=31536000" ".js"
  Header set Cache-Control "public, max-age=31536000" ".css"
  Header set Cache-Control "public, max-age=31536000" ".jpg"
  Header set Cache-Control "public, max-age=31536000" ".jpeg"
  Header set Cache-Control "public, max-age=31536000" ".png"
  Header set Cache-Control "public, max-age=31536000" ".gif"
  Header set Cache-Control "public, max-age=31536000" ".svg"
  Header set Cache-Control "public, max-age=31536000" ".woff"
  Header set Cache-Control "public, max-age=31536000" ".woff2"
  Header set Cache-Control "public, max-age=3600" ".html"
</IfModule>
